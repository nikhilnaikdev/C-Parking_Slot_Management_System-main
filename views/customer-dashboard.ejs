<%- include("partials/header") %>

<div class="row g-4">
  <div class="col-lg-3"><%- include("partials/customer-sidebar") %></div>
  <div class="col-lg-9">
    <div class="page-titlebar">
      <span class="eyebrow">Customer dashboard</span>
      <h2>Welcome, <%= customer.full_name %></h2>
    </div>
    <div class="row g-3">
      <div class="col-md-4"><div class="stat-card"><span>Vehicles</span><strong><%= stats.vehicles %></strong></div></div>
      <div class="col-md-4"><div class="stat-card"><span>Bookings</span><strong><%= stats.bookings %></strong></div></div>
      <div class="col-md-4"><div class="stat-card"><span>Receipts</span><strong><%= stats.receipts %></strong></div></div>
    </div>
    <div class="content-panel mt-4">
      <div class="panel-heading">
        <span class="eyebrow">Next step</span>
        <h5>Quick Actions</h5>
      </div>
      <div class="action-strip">
        <a href="/vehicle/add" class="btn btn-outline-primary">Register Vehicle</a>
        <a href="/parking/locations" class="btn btn-outline-primary">View Locations</a>
        <a href="/parking/book" class="btn btn-primary">Book Slot</a>
        <a href="/booking/history" class="btn btn-warning">Booking / Bill Status</a>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
