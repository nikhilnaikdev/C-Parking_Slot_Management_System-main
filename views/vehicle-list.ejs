<%- include("partials/header") %>

<div class="row g-4">
  <div class="col-lg-3"><%- include("partials/customer-sidebar") %></div>
  <div class="col-lg-9">
    <div class="content-panel">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="panel-heading mb-0">
          <span class="eyebrow">Garage</span>
          <h2>My Vehicles</h2>
        </div>
        <a href="/vehicle/add" class="btn btn-primary">Add Vehicle</a>
      </div>
      <div class="table-responsive">
        <table class="table table-striped align-middle">
          <thead>
            <tr>
              <th>Reg No</th>
              <th>Make</th>
              <th>Model</th>
              <th>Type</th>
              <th>Added</th>
            </tr>
          </thead>
          <tbody>
            <% if (vehicles.length === 0) { %>
              <tr><td colspan="5" class="text-center">No vehicles added yet.</td></tr>
            <% } %>
            <% vehicles.forEach(vehicle => { %>
              <tr>
                <td><%= vehicle.vehicle_reg_no %></td>
                <td><%= vehicle.vehicle_make %></td>
                <td><%= vehicle.vehicle_model %></td>
                <td><%= vehicle.vehicle_type %></td>
                <td><%= new Date(vehicle.created_at).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
