<%- include("partials/header") %>

<div class="auth-layout">
  <div class="auth-aside">
    <span class="eyebrow">Customer access</span>
    <h1>Reserve faster, park cleaner.</h1>
    <p>Sign in to manage vehicles, active tickets, receipts, and slot bookings from one focused workspace.</p>
  </div>

  <div class="auth-card">
    <span class="eyebrow">Welcome back</span>
    <h2>Customer Login</h2>
    <form action="/login" method="POST">
      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" required>
      </div>
      <button class="btn btn-primary w-100">Login</button>
    </form>
    <p class="auth-switch">New customer? <a href="/signup">Create account</a></p>
  </div>
</div>

<%- include("partials/footer") %>
